<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <EditTextPreference
        android:key="@string/db_url"
        android:title="Database URL"
        app:useSimpleSummaryProvider="true" />

    <ListPreference
        android:key="@string/pref_left_side"
        android:title="Left Side Detail"
        app:useSimpleSummaryProvider="true"
        android:entries="@array/pref_display_entries"
        android:defaultValue="@string/pref_display_ipv4"
        android:entryValues="@array/pref_display_values"/>
        />
    <ListPreference
        android:key="@string/pref_right_side"
        android:title="Right Side Detail"
        app:useSimpleSummaryProvider="true"
        android:defaultValue="@string/pref_display_hostname"
        android:entries="@array/pref_display_entries"
        android:entryValues="@array/pref_display_values"/>
    />
    <SwitchPreference
        android:key="@string/pref_pro_json"
        android:title="Export Technical JSON"
        app:useSimpleSummaryProvider="true"
        android:defaultValue="false"
        />
</androidx.preference.PreferenceScreen>